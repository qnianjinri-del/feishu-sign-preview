{
  "name": "feishu-sign-preview",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Private-deployable Feishu link preview service for signature-style inline previews.",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/app.js",
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "node --test --import tsx test/*.test.ts"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.42.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
